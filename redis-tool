#!/usr/bin/env python3
import sys
import shutil
import subprocess
import re
import argparse
import os

def check_prerequisites():
    runtime = None
    if shutil.which("podman"):
        runtime = "podman"
    else:
        try:
            res = subprocess.run("docker --version", shell=True, capture_output=True, text=True)
            if res.returncode == 0:
                runtime = "docker"
        except Exception:
            pass
            
    if not runtime:
        print("✗ Container runtime not found (Docker or Podman)")
        sys.exit(1)
        
    if not shutil.which("ansible-playbook"):
        print("✗ Ansible not found")
        sys.exit(1)
        
    return runtime

def run_provision(version):
    print(f"Starting deployment for Redis version: {version}...")
    
    # Run the playbook directly from python using subprocess
    cmd = [
        "ansible-playbook", 
        "ansible/playbooks/provision.yml", 
        "--extra-vars", f"redis_version={version}"
    ]
    
    # Injecting the ANSIBLE_CONFIG environment variable ensures Ansible loads our local cfg file
    env = os.environ.copy()
    env["ANSIBLE_CONFIG"] = "./ansible/ansible.cfg"
    
    result = subprocess.run(cmd, env=env)
    
    if result.returncode == 0:
        print("\n=========================================")
        print("✓ REDIS CLUSTER PROVISIONED SUCCESSFULLY!")
        print("=========================================")
    else:
        print("\n✗ Deployment failed during provisioning tasks.")
        sys.exit(1)

def main():
    check_prerequisites()
    
    parser = argparse.ArgumentParser(description="Redis Cluster Lifecycle Management CLI Tool")
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    # Provision command parsing [cite: 30]
    prov_parser = subparsers.add_parser("provision", help="Provision a clean Redis Cluster")
    prov_parser.add_argument("version_label", choices=["version"], help="Version specification keyword")
    prov_parser.add_argument("version_num", help="Exact target version string (e.g., 7.0.15)")
    prov_parser.add_argument("--masters", type=int, default=3, help="Number of master nodes")
    prov_parser.add_argument("--replicas-per-master", type=int, default=1, help="Replicas assigned per master")

    args = parser.parse_args()
    
    if args.command == "provision":
        run_provision(args.version_num)

if __name__ == "__main__":
    main()