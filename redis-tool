RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
BLUE = "\033[0;34m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
NC = "\033[0m"


def _ts():
    return datetime.now().strftime("%H:%M:%S")


def write_op_log(action, outcome="success", details=None):
    try:
        entry = {
            "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
            "command": sys.argv[1] if len(sys.argv) > 1 else "unknown",
            "action": action,
            "outcome": outcome,
            "details": details or {}
        }
        with open(OP_LOG_FILE, "a") as f:
            f.write(json.dumps(entry) + "\n")
    except Exception:
        pass


def log_info(msg):
    print(f"{GREEN}[INFO]{NC}  {_ts()} {msg}")


def log_warn(msg):
    print(f"{YELLOW}[WARN]{NC}  {_ts()} {msg}")


def log_error(msg):
    print(f"{RED}[ERROR]{NC} {_ts()} {msg}", file=sys.stderr)
    write_op_log(msg, outcome="error")


def log_step(msg):
    print(f"{CYAN}[STEP]{NC}  {_ts()} {msg}")
    write_op_log(msg, outcome="started")


def log_ok(msg):
    print(f"{GREEN}[✔]{NC}    {msg}")
    write_op_log(msg, outcome="success")


def log_fail(msg):
    print(f"{RED}[✘]{NC}    {msg}")
    write_op_log(msg, outcome="failure")


def header(title):
    print()
    print(f"{BOLD}{BLUE}{'═' * 60}{NC}")
    print(f"{BOLD}{BLUE}  {title}{NC}")
    print(f"{BOLD}{BLUE}{'═' * 60}{NC}")
    print()


def abort(msg):
    log_fail(msg)
    sys.exit(1)

def run(cmd, cwd=None, check=True, capture=True):
    """Run a shell command, return CompletedProcess."""
    result = subprocess.run(
        cmd, shell=True, cwd=cwd,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.STDOUT if capture else None,
        text=True,
    )
    if check and result.returncode != 0:
        log_error(f"Command failed: {cmd}")
        if capture and result.stdout:
            print(result.stdout)
        raise subprocess.CalledProcessError(result.returncode, cmd, output=result.stdout)
    return result


def run_live(cmd, cwd=None, check=True):
    """Run command with live stdout/stderr output."""
    proc = subprocess.run(cmd, shell=True, cwd=cwd)
    if check and proc.returncode != 0:
        log_error(f"Command failed (rc={proc.returncode}): {cmd}")
        raise subprocess.CalledProcessError(proc.returncode, cmd)
    return proc


def ssh_cmd(ip, remote_cmd):
    """Run a command on a container node via SSH."""
    port = SSH_PORTS.get(ip, 22)
    full = (
        f"ssh -i {SSH_KEY} -p {port} -o StrictHostKeyChecking=no "
        f"-o UserKnownHostsFile=/dev/null -o ConnectTimeout=5 "
        f"-o LogLevel=ERROR "
        f'ansible@127.0.0.1 "sudo {remote_cmd}"'
    )
    r = run(full, check=False)
    return r.stdout.strip() if r.stdout else "", r.returncode


def redis_cli(ip, redis_cmd, port=6379):
    """Execute redis-cli on a remote node, return stdout."""
    out, rc = ssh_cmd(ip, f"/opt/redis/bin/redis-cli -h 127.0.0.1 -p {port} {redis_cmd}")
    if rc != 0:
        return ""
    if not out:
        return ""
    lines = [line for line in out.splitlines() if not line.startswith("Warning:")]
    return "\n".join(lines).strip()

CONTAINER_ENGINE = ""
COMPOSE_CMD = ""
PREFLIGHT_DONE = False


def detect_container_engine(auto_install=False):
    global CONTAINER_ENGINE, COMPOSE_CMD
    version_str = ""
    if shutil.which("podman"):
        CONTAINER_ENGINE = "podman"
        COMPOSE_CMD = "podman-compose" if shutil.which("podman-compose") else "podman compose"
        r = subprocess.run("podman --version", shell=True, capture_output=True, text=True)
        m = re.search(r"(\d+\.\d+\.\d+)", r.stdout)
        version_str = m.group(1) if m else "found"
    elif shutil.which("docker"):
        CONTAINER_ENGINE = "docker"
        r = subprocess.run("docker compose version", shell=True, capture_output=True)
        if r.returncode == 0:
            COMPOSE_CMD = "docker compose"
        elif shutil.which("docker-compose"):
            COMPOSE_CMD = "docker-compose"
        else:
            abort("Docker found but no compose plugin available")
        r = subprocess.run("docker --version", shell=True, capture_output=True, text=True)
        m = re.search(r"(\d+\.\d+\.\d+)", r.stdout)
        version_str = m.group(1) if m else "found"
    else:
        log_fail("Container runtime not found (Docker or Podman)")
        if auto_install:
            ans = input("Would you like to auto-install Podman? [y/N]: ")
            if ans.lower() == 'y':
                run_live("sudo apt-get update && sudo apt-get install -y podman podman-compose")
                return detect_container_engine(auto_install=False)

        print("  Install Podman: https://podman.io/docs/installation")
        print("  Install Docker: https://docs.docker.com/engine/install/")
        sys.exit(1)

    version_label = version_str if version_str != "found" else "detected"
    log_ok(f"{CONTAINER_ENGINE.capitalize()} {version_label} found")


def detect_ansible(auto_install=False):
    if not shutil.which("ansible-playbook"):
        log_fail("Ansible not found")
        if auto_install:
            ans = input("Would you like to auto-install Ansible? [y/N]: ")
            if ans.lower() == 'y':
                run_live("pip3 install ansible>=2.14")
                return detect_ansible(auto_install=False)

        print("  Install:  pip install ansible  (or use your OS package manager)")
        sys.exit(1)
    r = run("ansible --version", check=False)
    version_str = ""
    for line in (r.stdout or "").splitlines():
        m = re.search(r"(\d+\.\d+[\.\d]*)", line)
        if m:
            version_str = m.group(1)
            break
    if version_str:
        major, minor = map(int, version_str.split(".")[:2])
        if major < 2 or (major == 2 and minor < 14):
            abort(f"Ansible 2.14+ required, found {version_str}")
    log_ok(f"Ansible {version_str or 'detected'} found")


def preflight(auto_install=False):
    global PREFLIGHT_DONE
    if PREFLIGHT_DONE:
        return
    header("Preflight Checks")
    detect_container_engine(auto_install)
    detect_ansible(auto_install)
    print("Proceeding...")
    print()
    PREFLIGHT_DONE = True

def ensure_ssh_keys():
    if not os.path.exists(SSH_KEY):
        log_step("Generating SSH keypair for Ansible...")
        os.makedirs(SSH_KEY_DIR, exist_ok=True)
        run(f'ssh-keygen -t rsa -b 4096 -f {SSH_KEY} -N "" -q')
        log_ok("SSH keypair generated")
    else:
        log_ok("SSH keypair exists")


def ensure_compose_network():
    """Remove stale compose networks that do not match the required subnet."""
    network_name = "infra_redis-cluster-net"
    if CONTAINER_ENGINE not in {"podman", "docker"}:
        return

    legacy_network = "infra_redis_net"
    legacy_result = run(f"{CONTAINER_ENGINE} network inspect {legacy_network}", check=False)
    if legacy_result.returncode == 0:
        log_warn(f"Removing legacy {legacy_network}; current compose network is {network_name}")
        run(f"{CONTAINER_ENGINE} network rm {legacy_network}", check=False)

    result = run(f"{CONTAINER_ENGINE} network inspect {network_name}", check=False)
    if result.returncode != 0:
        return

    if "10.10.0.0/24" in (result.stdout or ""):
        return

    log_warn(f"Removing stale {network_name}; expected subnet is 10.10.0.0/24")
    run(f"{CONTAINER_ENGINE} network rm {network_name}", check=False)


def ensure_required_subnet_available():
    """Fail early when the required fixed subnet is already reserved on the host."""
    route = run("ip route show 10.10.0.0/24", check=False)
    if route.returncode != 0 or not (route.stdout or "").strip():
        return

    route_line = route.stdout.strip().splitlines()[0]
    if "infra_redis-cluster-net" in route_line:
        return

    iface = "unknown"
    match = re.search(r"\bdev\s+(\S+)", route_line)
    if match:
        iface = match.group(1)

    abort(
        "Required subnet 10.10.0.0/24 is already reserved on this host.\n"
        f"  Route: {route_line}\n"
        "  This blocks Podman from creating infra_redis-cluster-net.\n"
        "  If this is a stale bridge from a previous run, remove it and retry:\n"
        f"    sudo ip link delete {iface}\n"
        "  Then run:\n"
        "    ./redis-tool infra up"
    )


def cleanup_stale_project_containers(node_names):
    """Remove stopped/partial containers from prior failed compose runs."""
    for name in node_names:
        inspect = run(f"{CONTAINER_ENGINE} container inspect {name}", check=False)
        if inspect.returncode != 0:
            continue

        log_warn(f"Removing stale container {name} before compose up")
        run(f"{CONTAINER_ENGINE} stop {name}", check=False)
        run(f"{CONTAINER_ENGINE} rm -f {name}", check=False)


def ensure_required_ports_available(node_names):
    """Fail early if host SSH-forward ports are already occupied."""
    ports = [str(SSH_PORTS[NODES[name]]) for name in node_names]
    if not ports:
        return

    expr = " or ".join(f"sport = :{port}" for port in ports)
    result = run(f"ss -ltnp '( {expr} )'", check=False)
    lines = [
        line.strip()
        for line in (result.stdout or "").splitlines()
        if line.strip().startswith("LISTEN")
    ]
    if not lines:
        return

    pids = sorted(set(re.findall(r"pid=(\d+)", "\n".join(lines))), key=int)
    pid_hint = f"kill {' '.join(pids)}" if pids else "stop the process using the listed ports"

    abort(
        "Required SSH forward ports are already in use.\n"
        "  Busy listeners:\n"
        + "\n".join(f"    {line}" for line in lines)
        + "\n  If these are orphaned Podman rootlessport helpers from a failed run, clear them:\n"
        f"    {pid_hint}\n"
        "  Then retry:\n"
        "    ./redis-tool infra up"
    )


def infra_up(node_names=None):
    """Bring up container infrastructure and wait for SSH readiness."""
    node_names = node_names or BASE_NODE_NAMES
    node_ips = [NODES[name] for name in node_names]
    if node_names == BASE_NODE_NAMES:
        log_step("Bringing up 6-node container infrastructure...")
    else:
        log_step(f"Bringing up container infrastructure: {', '.join(node_names)}...")
    ensure_ssh_keys()
    ensure_compose_network()
    ensure_required_subnet_available()
    cleanup_stale_project_containers(node_names)
    ensure_required_ports_available(node_names)
    services = " ".join(node_names)
    run_live(f"cd {INFRA_DIR} && {COMPOSE_CMD} up -d --build {services}", check=True)
    log_step("Waiting for SSH on all nodes...")
    for ip in node_ips:
        for attempt in range(30):
            _, rc = ssh_cmd(ip, "echo ok")
            if rc == 0:
                break
            time.sleep(2)
        else:
            abort(f"SSH not reachable on {ip} after 30 attempts")
        log_ok(f"SSH ready: {ip}")


def infra_down():
    log_step("Tearing down infrastructure...")
    run_live(f"cd {INFRA_DIR} && {COMPOSE_CMD} down -v", check=False)
    # Clean up containers from BOTH engines to avoid port conflicts
    for engine in ("podman", "docker"):
        if shutil.which(engine):
            for i in range(1, 9):
                name = f"redis-node-{i}"
                run(f"{engine} stop {name}", check=False)
                run(f"{engine} rm -f {name}", check=False)
                run(f"{engine} volume rm -f infra_redis-data-{i}", check=False)
                run(f"{engine} volume rm -f redis-data-{i}", check=False)
            run(f"{engine} network rm infra_redis-cluster-net", check=False)
            run(f"{engine} network rm infra_redis_net", check=False)
    log_ok("Infrastructure destroyed")


def run_playbook(playbook, extra_vars=None, live=True):
    """Run an Ansible playbook. Returns CompletedProcess if live=False."""
    cmd = (
        f"ANSIBLE_CONFIG={ANSIBLE_DIR}/ansible.cfg "
        f"ansible-playbook -i {ANSIBLE_DIR}/inventory/hosts.ini "
        f"{ANSIBLE_DIR}/playbooks/{playbook} "
        f"--private-key={SSH_KEY}"
    )
    if extra_vars:
        for k, v in extra_vars.items():
            cmd += f' -e "{k}={v}"'
    if live:
        return run_live(cmd, check=True)
    else:
        return run(cmd, check=False)


def wait_replica_sync(ip, timeout=60, delay=2):
    """Block until replica node's master_link_status is 'up'."""
    log_step(f"Waiting for replica {ip} to synchronize (master_link_status:up)...")
    for _ in range(int(timeout / delay)):
        try:
            repl = redis_cli(ip, "info replication")
            if "master_link_status:up" in repl:
                log_ok(f"Replica {ip} is fully synchronized.")
                return
        except Exception:
            pass
        time.sleep(delay)
    log_warn(f"Replica {ip} did not report master_link_status:up in time.")


def wait_cluster_ok(context="", retries=60, delay=3):
    """Block until cluster_state:ok or abort."""
    for _ in range(retries):
        out = redis_cli(BASE_IPS[0], "cluster info")
        if "cluster_state:ok" in out:
            log_ok(f"Cluster healthy {context}")
            return
        time.sleep(delay)
    abort(f"Cluster did not recover {context}")


def get_cluster_nodes():
    """Parse 'cluster nodes' output into a list of dicts."""
    raw = redis_cli(BASE_IPS[0], "cluster nodes")
    nodes = []
    for line in raw.splitlines():
        parts = line.split()
        if len(parts) < 4:
            continue
        nid = parts[0]
        ip = parts[1].split("@")[0].rsplit(":", 1)[0]
        flags = parts[2]
        master_id = parts[3]
        role = "master" if "master" in flags else "slave"
        nodes.append({
            "id": nid, "ip": ip, "flags": flags,
            "role": role, "master_id": master_id,
            "name": IP_TO_NAME.get(ip, ip),
        })
    return nodes


def cmd_provision(args):
    version = args.version
    masters = args.masters
    replicas = args.replicas_per_master
    header(f"Provisioning Redis Cluster v{version} ({masters}M + {masters * replicas}R)")
    preflight(getattr(args, 'auto_install', False))

    log_step("Checking if cluster is already provisioned...")
    try:
        out = redis_cli(BASE_IPS[0], "cluster info")
        if "cluster_state:ok" in out:
            info = redis_cli(BASE_IPS[0], "INFO server")
            current_version = next((l.split(":")[1].strip() for l in info.splitlines() if l.startswith("redis_version:")), None)
            if current_version == version:
                log_ok("Cluster is already provisioned and healthy. No operation needed.")
                return
            else:
                log_info(f"Cluster is running v{current_version}, but requested v{version}. Proceeding with clean provision.")
    except Exception:
        pass

    log_step("Cleaning up any previous infrastructure...")
    infra_down()
    infra_up()
    log_step(f"Installing Redis {version} on all nodes...")
    run_playbook("provision.yml", extra_vars={
        "redis_version_override": version,
        "masters_count_override": str(masters),
        "replicas_per_master_override": str(replicas),
    })
    log_ok("Provision complete!")



def cmd_status(_args):
    header("Redis Cluster Status")
    preflight(getattr(_args, 'auto_install', False))

    # Run status playbook silently to satisfy the requirement
    run_playbook("status.yml", live=False)

    try:
        info_raw = redis_cli(BASE_IPS[0], "cluster info")
        c_state = "ok" if "cluster_state:ok" in info_raw else "fail"
    except Exception:
        c_state = "fail"

    print(f"Cluster State: {c_state}\n")

    nodes = get_cluster_nodes()

    masters = []
    replicas = []

    for n in nodes:
        ip = n["ip"]
        try:
            info_server = redis_cli(ip, "INFO server")
            ver = next((l.split(":")[1].strip() for l in info_server.splitlines() if l.startswith("redis_version:")), "?")
            info_mem = redis_cli(ip, "INFO memory")
            mem = next((l.split(":")[1].strip() for l in info_mem.splitlines() if l.startswith("used_memory_human:")), "?")
        except Exception:
            ver = "?"
            mem = "?"

        n["ver"] = "v" + ver
        n["mem"] = mem

        if n["role"] == "master":
            try:
                db_size = redis_cli(ip, "DBSIZE")
                keys = db_size.strip()
            except Exception:
                keys = "?"

            slots = []
            try:
                raw_nodes = redis_cli(ip, "cluster nodes")
                for line in raw_nodes.splitlines():
                    if n["id"] in line and "master" in line:
                        parts = line.split()
                        slots = [p for p in parts[8:] if not p.startswith("[")]
            except Exception:
                pass

            n["keys"] = keys
            n["slots"] = " ".join(slots)
            masters.append(n)
        else:
            replicas.append(n)

    # Sort for consistent output
    masters.sort(key=lambda x: x["ip"])
    replicas.sort(key=lambda x: x["ip"])

    id_to_ip = {n["id"]: f"{n['ip']}:6379" for n in nodes}

    print("MASTERS")
    for m in masters:
        print(f" {m['ip']}:6379  [master]  {m['ver']:<8} slots: {m['slots']:<11} keys: {m['keys']:<4} mem: {m['mem']}")

    print("\nREPLICAS")
    for r in replicas:
        master_ip_port = id_to_ip.get(r["master_id"], "?")
        print(f" {r['ip']}:6379  [replica] {r['ver']:<8} replicating: {master_ip_port:<15} mem: {r['mem']}")



def write_seed_count(count):
    try:
        with open(SEED_COUNT_FILE, "w") as f:
            f.write(str(count))
    except OSError:
        log_warn("Unable to persist seed key count")


def read_seed_count():
    if not os.path.exists(SEED_COUNT_FILE):
        return None
    try:
        with open(SEED_COUNT_FILE, "r") as f:
            return int(f.read().strip())
    except (OSError, ValueError):
        return None


def cmd_data_seed(args):
    header(f"Seeding {args.keys} Keys")
    preflight(getattr(args, 'auto_install', False))
    run_playbook("seed.yml", extra_vars={"num_keys": str(args.keys)})
    write_seed_count(args.keys)


def cmd_data_verify(args):
    seed_count = args.keys
    if seed_count is None:
        seed_count = read_seed_count() or 1000
        log_info(f"No --keys provided; using last seeded count: {seed_count}")
    header(f"Verifying Data Integrity ({seed_count} keys)")
    preflight(getattr(args, 'auto_install', False))
    run_playbook("verify.yml", extra_vars={"num_keys": str(seed_count)})

def cmd_rollback(args):
    header(f"Rolling Back to Redis {args.target_version}")
    preflight(getattr(args, 'auto_install', False))

    log_step(f"Performing clean rollback and reinstall to v{args.target_version}...")
    run_playbook("provision.yml", extra_vars={
        "redis_version_override": args.target_version,
        "masters_count_override": "3",
        "replicas_per_master_override": "1",
        "force_reset": "true",
    })

    log_step("Restoring data integrity by re-seeding deterministic keys...")
    run_playbook("seed.yml", extra_vars={"num_keys": str(read_seed_count() or 1000)})

    log_step("Verifying data integrity post-rollback...")
    run_playbook("verify.yml", extra_vars={"num_keys": str(read_seed_count() or 1000)})

    header(f"Rollback Complete — All Nodes at v{args.target_version}")
    log_ok("Data integrity: VERIFIED")
    log_ok("Cluster state: OK")


def cmd_scale(args):
    header("Scaling Redis Cluster")
    preflight(getattr(args, 'auto_install', False))

    if args.add_nodes:
        if args.add_nodes != 2:
            abort("Currently only supports adding exactly 2 nodes (1M + 1R)")

        log_step("Starting and provisioning new nodes (node 7 and 8)...")
        infra_up(SCALE_NODE_NAMES)
        info = redis_cli(BASE_IPS[0], "INFO server")
        ver = next((l.split(":")[1].strip() for l in info.splitlines() if l.startswith("redis_version:")), "7.0.15")

        run_playbook("provision.yml", extra_vars={
            "target_hosts": "redis_scale_nodes",
            "redis_version_override": ver
        })

        log_step("Adding Node 7 as Master...")
        ssh_cmd(BASE_IPS[0], "/opt/redis/bin/redis-cli --cluster add-node 10.10.0.17:6379 10.10.0.11:6379")
        time.sleep(2)

        log_step("Retrieving Node 7 ID...")
        nodes = get_cluster_nodes()
        n7 = next((n for n in nodes if n["ip"] == "10.10.0.17"), None)
        if not n7:
            abort("Node 7 failed to join cluster")

        log_step("Adding Node 8 as Replica to Node 7...")
        ssh_cmd(BASE_IPS[0], f"/opt/redis/bin/redis-cli --cluster add-node 10.10.0.18:6379 10.10.0.11:6379 --cluster-slave --cluster-master-id {n7['id']}")
        time.sleep(2)

        log_step("Rebalancing Cluster Slots...")
        ssh_cmd(BASE_IPS[0], "/opt/redis/bin/redis-cli --cluster rebalance 10.10.0.11:6379 --cluster-use-empty-masters")
        log_ok("Scale out complete!")

    elif args.remove_node:
        node_id = args.remove_node
        log_step(f"Removing Node {node_id} from cluster...")
        nodes = get_cluster_nodes()
        target = next((n for n in nodes if n["id"] == node_id), None)
        if not target:
            abort(f"Node {node_id} not found")

        replica_id = None
        if target["role"] == "master":
            replica = next((n for n in nodes if n["role"] == "slave" and n["master_id"] == node_id), None)
            if replica:
                replica_id = replica["id"]
                log_info(f"Associated replica for master {node_id} is {replica_id} ({replica['name']})")
        else:
            master_id = target["master_id"]
            master = next((n for n in nodes if n["id"] == master_id), None)
            if master:
                log_info(f"Associated master for replica {node_id} is {master_id} ({master['name']})")
                replica_id = node_id
                node_id = master_id
                target = master

        if target["role"] == "master":
            log_step("Resharding slots away from master...")
            slots = 0
            try:
                raw_nodes = redis_cli(target["ip"], "cluster nodes")
                for line in raw_nodes.splitlines():
                    if node_id in line and "master" in line:
                        parts = line.split()
                        slots_list = [p for p in parts[8:] if not p.startswith("[")]
                        for s in slots_list:
                            if "-" in s:
                                start, end = map(int, s.split("-"))
                                slots += (end - start + 1)
                            else:
                                slots += 1
            except Exception:
                pass

            if slots > 0:
                other_master = next((n for n in nodes if n["role"] == "master" and n["id"] != node_id), None)
                if other_master:
                    log_info(f"Moving {slots} slots to master {other_master['id']} ({other_master['name']})")
                    ssh_cmd(BASE_IPS[0], f"/opt/redis/bin/redis-cli --cluster reshard 10.10.0.11:6379 --cluster-from {node_id} --cluster-to {other_master['id']} --cluster-slots {slots} --cluster-yes")
                    time.sleep(5)
                else:
                    abort("No other master found to receive slots!")

        if replica_id:
            log_step(f"Deleting replica node {replica_id} from cluster...")
            ssh_cmd(BASE_IPS[0], f"/opt/redis/bin/redis-cli --cluster del-node 10.10.0.11:6379 {replica_id}")
            time.sleep(2)

        log_step(f"Deleting master node {node_id} from cluster...")
        ssh_cmd(BASE_IPS[0], f"/opt/redis/bin/redis-cli --cluster del-node 10.10.0.11:6379 {node_id}")
        log_ok("Scale in complete!")
    else:
        abort("Must specify --add-nodes or --remove-node")

def cmd_upgrade(args, is_rollback=False):
    target = args.target_version
    op_name = "Downgrade" if is_rollback else "Upgrade"
    if not is_rollback:
        header(f"Rolling Upgrade to Redis {target}")
    preflight(getattr(args, 'auto_install', False))

    log_step("Step 1/5: Pre-flight health checks...")
    try:
        cluster_info = redis_cli(BASE_IPS[0], "cluster info")
        if "cluster_state:ok" not in cluster_info:
            abort(f"{op_name} pre-flight check failed: Cluster is not healthy")
        log_ok("Cluster state: ok")
    except Exception as e:
        abort(f"{op_name} pre-flight check failed: Could not query cluster state: {e}")

    cluster_ips = sorted({n["ip"] for n in get_cluster_nodes()}) or BASE_IPS
    for ip in cluster_ips:
        try:
            if redis_cli(ip, "ping").strip() != "PONG":
                abort(f"{op_name} pre-flight check failed: Node {ip} did not respond to ping")
            log_ok(f"Node {ip}: reachable")
        except Exception as e:
            abort(f"{op_name} pre-flight check failed: Node {ip} is unreachable: {e}")

    versions = []
    for ip in cluster_ips:
        try:
            info = redis_cli(ip, "INFO server")
            ver = next((l.split(":")[1].strip() for l in info.splitlines() if l.startswith("redis_version:")), "?")
            versions.append(ver)
        except Exception:
            versions.append("?")

    unique_versions = set(versions)
    if len(unique_versions) == 1 and target in unique_versions:
        log_ok(f"All nodes are already running target version v{target}. {op_name} is a no-op.")
        return

    log_step("Baseline data verification...")
    try:
        run_playbook("verify.yml", extra_vars={"num_keys": str(read_seed_count() or 1000)})
        log_ok("Baseline data: intact")
    except Exception as e:
        abort(f"{op_name} pre-flight check failed: Pre-upgrade baseline data verification failed: {e}")

    log_step("Step 2/5: Discovering cluster topology...")
    nodes = get_cluster_nodes()
    replicas = [n for n in nodes if n["role"] == "slave"]
    masters = [n for n in nodes if n["role"] == "master"]
    log_info(f"Masters:  {', '.join(n['name'] for n in masters)}")
    log_info(f"Replicas: {', '.join(n['name'] for n in replicas)}")

    total_nodes = len(replicas) + len(masters)
    upgraded_count = 0

    log_step("Step 3/5: Upgrading replicas...")
    for rep in replicas:
        log_step(f"Upgrading replica {rep['name']} ({rep['ip']})...")
        try:
            run_playbook("upgrade.yml", extra_vars={
                "upgrade_node": rep["name"], "target_version": target,
            })
            wait_replica_sync(rep["ip"])
            wait_cluster_ok(f"after upgrading {rep['name']}")
            upgraded_count += 1
            print(f"[{upgraded_count}/{total_nodes}] Upgraded replica {rep['ip']} — cluster: ok")
            log_ok(f"Replica {rep['name']} upgraded")
        except Exception as e:
            log_error(f"{op_name} failed on replica node {rep['name']} ({rep['ip']}) during software build/install or cluster joining.")
            sys.exit(1)

    log_step("Step 4/5: Upgrading masters with failover...")
    nodes = get_cluster_nodes()  # re-discover after replica upgrades
    masters = [n for n in nodes if n["role"] == "master"]
    rep_for_master = {}
    for n in nodes:
        if n["role"] == "slave":
            rep_for_master[n["master_id"]] = n

    for master in masters:
        mname, mip, mid = master["name"], master["ip"], master["id"]
        rep = rep_for_master.get(mid)
        if not rep:
            log_error(f"{op_name} failed: No replica found for master {mname} ({mip})")
            sys.exit(1)

        try:
            log_step(f"Failing over {mname} → promoting {rep['name']}...")
            redis_cli(rep["ip"], "CLUSTER FAILOVER")

            for _ in range(30):
                if "role:master" in redis_cli(rep["ip"], "INFO replication"):
                    log_ok(f"Failover done: {rep['name']} is master")
                    break
                time.sleep(2)
            else:
                log_error(f"{op_name} failed on master node {mname} ({mip}) during failover to replica {rep['name']}")
                sys.exit(1)

            wait_cluster_ok(f"after failover of {mname}")

            log_step(f"Upgrading old master {mname} (now replica)...")
            run_playbook("upgrade.yml", extra_vars={
                "upgrade_node": mname, "target_version": target,
            })
            wait_replica_sync(mip)
            wait_cluster_ok(f"after upgrading {mname}")
            upgraded_count += 1
            print(f"[{upgraded_count}/{total_nodes}] Upgraded master {mip} — cluster: ok")
            log_ok(f"Master {mname} upgraded")
        except Exception as e:
            log_error(f"{op_name} failed on master node {mname} ({mip}) during software build/install or cluster verification: {e}")
            sys.exit(1)

    log_step("Step 5/5: Post-upgrade verification...")
    try:
        run_playbook("verify.yml", extra_vars={"num_keys": str(read_seed_count() or 1000)})
        run_playbook("status.yml")
    except Exception as e:
        log_error(f"Post-{op_name.lower()} verification playbook run failed: {e}")
        sys.exit(1)

    header(f"{op_name} Complete — All Nodes at v{target}")
    log_ok("Data integrity: VERIFIED")
    log_ok("Cluster state: OK")
    log_ok(f"Zero-downtime rolling {op_name.lower()} successful!")


def cmd_verify(args):
    header("Full Cluster Verification")
    preflight(getattr(args, 'auto_install', False))

    results = {}

    log_step("1. Data integrity check...")
    try:
        run_playbook("verify.yml", extra_vars={"num_keys": str(read_seed_count() or 1000)})
        log_ok("Data integrity: PASS")
        results["Data Integrity"] = True
    except Exception:
        log_fail("Data integrity: FAIL")
        results["Data Integrity"] = False

    log_step("2. Version consistency...")
    try:
        versions = []
        cluster_ips = sorted({n["ip"] for n in get_cluster_nodes()}) or BASE_IPS
        for ip in cluster_ips:
            info = redis_cli(ip, "INFO server")
            ver = next((l.split(":")[1].strip() for l in info.splitlines()
                         if l.startswith("redis_version:")), "?")
            versions.append(ver)
            log_info(f"  {ip} ({IP_TO_NAME.get(ip)}): v{ver}")
        unique = set(v for v in versions if v != "?")
        if len(unique) == 1:
            log_ok(f"Version consistency: PASS (all v{unique.pop()})")
            results["Version Consistency"] = True
        else:
            log_fail(f"Version consistency: FAIL (mixed: {unique})")
            results["Version Consistency"] = False
    except Exception:
        results["Version Consistency"] = False

    log_step("3. Cluster state...")
    try:
        info = redis_cli(BASE_IPS[0], "cluster info")
        if "cluster_state:ok" in info:
            log_ok("Cluster state: OK")
            results["Cluster State"] = True
        else:
            log_fail("Cluster state: FAIL")
            results["Cluster State"] = False
    except Exception:
        results["Cluster State"] = False

    log_step("4. Slot coverage...")
    try:
        slots_ok = False
        for line in info.splitlines():
            if "cluster_slots_ok" in line:
                slots = line.split(":")[1].strip()
                if slots == "16384":
                    log_ok(f"Slot coverage: {slots}/16384")
                    slots_ok = True
                else:
                    log_fail(f"Slot coverage: {slots}/16384")
        results["Slot Coverage"] = slots_ok
    except Exception:
        results["Slot Coverage"] = False

    if args.full:
        log_step("5. Replication lag...")
        try:
            rep_pass = True
            for ip in cluster_ips:
                repl = redis_cli(ip, "INFO replication")
                if "role:slave" in repl:
                    link_up = any("master_link_status:up" in l for l in repl.splitlines())
                    offsets = [l for l in repl.splitlines() if "repl_offset" in l]
                    if not link_up:
                        rep_pass = False
                    log_info(f"  {ip} (replica): master_link_status={'up' if link_up else 'down'} | {'; '.join(offsets)}")
            if rep_pass:
                log_ok("Replication lag: PASS — all replicas have master_link_status:up")
                results["Replication Lag"] = True
            else:
                log_fail("Replication lag: FAIL — some replicas have master_link_status:down")
                results["Replication Lag"] = False
        except Exception:
            results["Replication Lag"] = False

    header("Verification Summary")
    for check, passed in sorted(results.items()):
        status_str = f"{GREEN}PASS{NC}" if passed else f"{RED}FAIL{NC}"
        print(f" - {check:<25}: {status_str}")
    print()
    
    if all(results.values()):
        log_ok("All checks passed!")
    else:
        abort("Some checks failed!")


def cmd_infra_up(_args):
    preflight(getattr(_args, 'auto_install', False))
    infra_up()


def cmd_infra_down(args):
    preflight(getattr(args, 'auto_install', False))
    infra_down()


BANNER = """
  ╔══════════════════════════════════════════════════════╗
  ║          redis-tool · Cluster Lifecycle CLI          ║
  ╚══════════════════════════════════════════════════════╝
"""

def main():
    parser = argparse.ArgumentParser(
        prog="redis-tool",
        description="Redis Cluster Lifecycle CLI — provision, operate, and upgrade.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=BANNER,
    )
    parser.add_argument("--auto-install", action="store_true", help="Auto-install missing dependencies")
    sub = parser.add_subparsers(dest="command", help="Available commands")

    p = sub.add_parser("provision", help="Provision a Redis Cluster")
    p.add_argument("--version", default="7.0.15")
    p.add_argument("--masters", type=int, default=3)
    p.add_argument("--replicas-per-master", type=int, default=1)
    p.set_defaults(func=cmd_provision)

    p = sub.add_parser("status", help="Show cluster status")
    p.set_defaults(func=cmd_status)

    p_data = sub.add_parser("data", help="Seed or verify data")
    ds = p_data.add_subparsers(dest="data_cmd")
    p = ds.add_parser("seed", help="Seed test data")
    p.add_argument("--keys", type=int, default=1000)
    p.set_defaults(func=cmd_data_seed)
    p = ds.add_parser("verify", help="Verify data integrity")
    p.add_argument("--keys", type=int, default=None)
    p.set_defaults(func=cmd_data_verify)

    p = sub.add_parser("upgrade", help="Rolling upgrade")
    p.add_argument("--target-version", required=True)
    p.add_argument("--strategy", default="rolling", choices=["rolling"])
    p.set_defaults(func=cmd_upgrade)

    p = sub.add_parser("rollback", help="Rollback upgrade")
    p.add_argument("--target-version", required=True)
    p.set_defaults(func=cmd_rollback)

    p = sub.add_parser("scale", help="Scale cluster in or out")
    p.add_argument("--add-nodes", type=int, help="Number of nodes to add (must be multiple of 2)")
    p.add_argument("--remove-node", type=str, help="Node ID to remove")
    p.set_defaults(func=cmd_scale)

    p = sub.add_parser("verify", help="Full cluster verification")
    p.add_argument("--full", action="store_true")
    p.set_defaults(func=cmd_verify)

    p_infra = sub.add_parser("infra", help="Manage containers")
    isub = p_infra.add_subparsers(dest="infra_cmd")
    p = isub.add_parser("up", help="Bring up containers")
    p.set_defaults(func=cmd_infra_up)
    p = isub.add_parser("down", help="Tear down containers")
    p.set_defaults(func=cmd_infra_down)

    args = parser.parse_args()

    if not args.command:
        print(BANNER)
        parser.print_help()
        sys.exit(0)

    try:
        if hasattr(args, "func"):
            preflight(getattr(args, "auto_install", False))
            args.func(args)
        else:
            parser.parse_args([args.command, "--help"])
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)


if __name__ == "__main__":
    main()
