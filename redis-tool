#!/usr/bin/env python3
"""
redis-tool — Redis Cluster Lifecycle CLI
=========================================
Provisions, operates, and performs zero-downtime rolling upgrades
on a 6-node Redis Cluster (3M + 3R) with Ansible automation.

Usage:
    ./redis-tool provision --version 7.0.15 --masters 3 --replicas-per-master 1
    ./redis-tool data seed --keys 1000
    ./redis-tool data verify
    ./redis-tool status
    ./redis-tool upgrade --target-version 7.2.6 --strategy rolling
    ./redis-tool verify --full
    ./redis-tool infra up|down
"""

import argparse
import os
import re
import shutil
import subprocess
import sys
import time
from datetime import datetime

# ═══════════════════════════════════════════════════════════════════
# CONSTANTS & PATHS
# ═══════════════════════════════════════════════════════════════════

PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))
ANSIBLE_DIR = os.path.join(PROJECT_ROOT, "ansible")
INFRA_DIR = os.path.join(PROJECT_ROOT, "infra")
OUTPUT_DIR = os.path.join(PROJECT_ROOT, "output")
LOG_DIR = os.path.join(PROJECT_ROOT, "logs")
SSH_KEY_DIR = os.path.join(INFRA_DIR, "ssh_keys")
SSH_KEY = os.path.join(SSH_KEY_DIR, "id_rsa")

NODES = {
    "redis-node-1": "10.250.0.11",
    "redis-node-2": "10.250.0.12",
    "redis-node-3": "10.250.0.13",
    "redis-node-4": "10.250.0.14",
    "redis-node-5": "10.250.0.15",
    "redis-node-6": "10.250.0.16",
}
SSH_PORTS = {
    "10.250.0.11": 2211,
    "10.250.0.12": 2212,
    "10.250.0.13": 2213,
    "10.250.0.14": 2214,
    "10.250.0.15": 2215,
    "10.250.0.16": 2216,
}
ALL_IPS = list(NODES.values())
IP_TO_NAME = {v: k for k, v in NODES.items()}

for d in (OUTPUT_DIR, LOG_DIR):
    os.makedirs(d, exist_ok=True)

# ═══════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════

RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
BLUE = "\033[0;34m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
NC = "\033[0m"


def _ts():
    return datetime.now().strftime("%H:%M:%S")


def log_info(msg):
    print(f"{GREEN}[INFO]{NC}  {_ts()} {msg}")


def log_warn(msg):
    print(f"{YELLOW}[WARN]{NC}  {_ts()} {msg}")


def log_error(msg):
    print(f"{RED}[ERROR]{NC} {_ts()} {msg}", file=sys.stderr)


def log_step(msg):
    print(f"{CYAN}[STEP]{NC}  {_ts()} {msg}")


def log_ok(msg):
    print(f"{GREEN}[✔]{NC}    {msg}")


def log_fail(msg):
    print(f"{RED}[✘]{NC}    {msg}")


def header(title):
    print()
    print(f"{BOLD}{BLUE}{'═' * 60}{NC}")
    print(f"{BOLD}{BLUE}  {title}{NC}")
    print(f"{BOLD}{BLUE}{'═' * 60}{NC}")
    print()


def abort(msg):
    log_fail(msg)
    sys.exit(1)


# ═══════════════════════════════════════════════════════════════════
# SHELL & SSH HELPERS
# ═══════════════════════════════════════════════════════════════════


def run(cmd, cwd=None, check=True, capture=True):
    """Run a shell command, return CompletedProcess."""
    result = subprocess.run(
        cmd, shell=True, cwd=cwd,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.STDOUT if capture else None,
        text=True,
    )
    if check and result.returncode != 0:
        log_error(f"Command failed: {cmd}")
        if capture and result.stdout:
            print(result.stdout)
        sys.exit(result.returncode)
    return result


def run_live(cmd, cwd=None, check=True):
    """Run command with live stdout/stderr output."""
    proc = subprocess.run(cmd, shell=True, cwd=cwd)
    if check and proc.returncode != 0:
        log_error(f"Command failed (rc={proc.returncode}): {cmd}")
        sys.exit(proc.returncode)
    return proc


def ssh_cmd(ip, remote_cmd):
    """Run a command on a container node via SSH."""
    port = SSH_PORTS.get(ip, 22)
    full = (
        f"ssh -i {SSH_KEY} -p {port} -o StrictHostKeyChecking=no "
        f"-o UserKnownHostsFile=/dev/null -o ConnectTimeout=5 "
        f"-o LogLevel=ERROR "
        f'ansible@127.0.0.1 "sudo {remote_cmd}"'
    )
    r = run(full, check=False)
    return r.stdout.strip() if r.stdout else "", r.returncode


def redis_cli(ip, redis_cmd, port=6379):
    """Execute redis-cli on a remote node, return stdout."""
    out, _ = ssh_cmd(ip, f"/opt/redis/bin/redis-cli -h 127.0.0.1 -p {port} {redis_cmd}")
    if not out:
        return ""
    lines = [line for line in out.splitlines() if not line.startswith("Warning:")]
    return "\n".join(lines).strip()


# ═══════════════════════════════════════════════════════════════════
# PREREQUISITE DETECTION
# ═══════════════════════════════════════════════════════════════════

CONTAINER_ENGINE = ""
COMPOSE_CMD = ""


def detect_container_engine():
    global CONTAINER_ENGINE, COMPOSE_CMD
    if shutil.which("podman"):
        CONTAINER_ENGINE = "podman"
        COMPOSE_CMD = "podman-compose" if shutil.which("podman-compose") else "podman compose"
    elif shutil.which("docker"):
        CONTAINER_ENGINE = "docker"
        r = subprocess.run("docker compose version", shell=True, capture_output=True)
        if r.returncode == 0:
            COMPOSE_CMD = "docker compose"
        elif shutil.which("docker-compose"):
            COMPOSE_CMD = "docker-compose"
        else:
            abort("Docker found but no compose plugin available")
    else:
        abort(
            "Neither Docker nor Podman found!\n"
            "  Install Docker: https://docs.docker.com/get-docker/\n"
            "  Install Podman: https://podman.io/getting-started/installation"
        )
    log_ok(f"Container engine: {CONTAINER_ENGINE} ({COMPOSE_CMD})")


def detect_ansible():
    if not shutil.which("ansible-playbook"):
        abort("Ansible not found! Install: pip3 install ansible>=2.14")
    r = run("ansible --version", check=False)
    version_str = ""
    for line in (r.stdout or "").splitlines():
        m = re.search(r"(\d+\.\d+)", line)
        if m:
            version_str = m.group(1)
            break
    if version_str:
        major, minor = map(int, version_str.split("."))
        if major < 2 or (major == 2 and minor < 14):
            abort(f"Ansible 2.14+ required, found {version_str}")
    log_ok(f"Ansible: {version_str or 'detected'}")


def preflight():
    header("Preflight Checks")
    detect_container_engine()
    detect_ansible()
    print()


# ═══════════════════════════════════════════════════════════════════
# SSH KEYS & INFRASTRUCTURE
# ═══════════════════════════════════════════════════════════════════


def ensure_ssh_keys():
    if not os.path.exists(SSH_KEY):
        log_step("Generating SSH keypair for Ansible...")
        os.makedirs(SSH_KEY_DIR, exist_ok=True)
        run(f'ssh-keygen -t rsa -b 4096 -f {SSH_KEY} -N "" -q')
        log_ok("SSH keypair generated")
    else:
        log_ok("SSH keypair exists")


def infra_up():
    """Bring up 6 containers and wait for SSH readiness."""
    log_step("Bringing up 6-node container infrastructure...")
    ensure_ssh_keys()
    run_live(f"cd {INFRA_DIR} && {COMPOSE_CMD} up -d --build", check=True)
    log_step("Waiting for SSH on all nodes...")
    for ip in ALL_IPS:
        for attempt in range(30):
            _, rc = ssh_cmd(ip, "echo ok")
            if rc == 0:
                break
            time.sleep(2)
        else:
            abort(f"SSH not reachable on {ip} after 30 attempts")
        log_ok(f"SSH ready: {ip}")


def infra_down():
    log_step("Tearing down infrastructure...")
    run_live(f"cd {INFRA_DIR} && {COMPOSE_CMD} down -v", check=False)
    # Clean up containers from BOTH engines to avoid port conflicts
    for engine in ("podman", "docker"):
        if shutil.which(engine):
            for i in range(1, 7):
                name = f"redis-node-{i}"
                run(f"{engine} stop {name}", check=False)
                run(f"{engine} rm -f {name}", check=False)
                run(f"{engine} volume rm -f infra_redis-data-{i}", check=False)
                run(f"{engine} volume rm -f redis-data-{i}", check=False)
    log_ok("Infrastructure destroyed")


# ═══════════════════════════════════════════════════════════════════
# ANSIBLE RUNNER
# ═══════════════════════════════════════════════════════════════════


def run_playbook(playbook, extra_vars=None, live=True):
    """Run an Ansible playbook. Returns CompletedProcess if live=False."""
    cmd = (
        f"ANSIBLE_CONFIG={ANSIBLE_DIR}/ansible.cfg "
        f"ansible-playbook -i {ANSIBLE_DIR}/inventory/hosts.ini "
        f"{ANSIBLE_DIR}/playbooks/{playbook} "
        f"--private-key={SSH_KEY}"
    )
    if extra_vars:
        for k, v in extra_vars.items():
            cmd += f' -e "{k}={v}"'
    if live:
        return run_live(cmd, check=True)
    else:
        return run(cmd, check=False)


# ═══════════════════════════════════════════════════════════════════
# CLUSTER HELPERS
# ═══════════════════════════════════════════════════════════════════


def wait_cluster_ok(context="", retries=60, delay=3):
    """Block until cluster_state:ok or abort."""
    for _ in range(retries):
        out = redis_cli(ALL_IPS[0], "cluster info")
        if "cluster_state:ok" in out:
            log_ok(f"Cluster healthy {context}")
            return
        time.sleep(delay)
    abort(f"Cluster did not recover {context}")


def get_cluster_nodes():
    """Parse 'cluster nodes' output into a list of dicts."""
    raw = redis_cli(ALL_IPS[0], "cluster nodes")
    nodes = []
    for line in raw.splitlines():
        parts = line.split()
        if len(parts) < 4:
            continue
        nid = parts[0]
        ip = parts[1].split("@")[0].rsplit(":", 1)[0]
        flags = parts[2]
        master_id = parts[3]
        role = "master" if "master" in flags else "slave"
        nodes.append({
            "id": nid, "ip": ip, "flags": flags,
            "role": role, "master_id": master_id,
            "name": IP_TO_NAME.get(ip, ip),
        })
    return nodes


# ═══════════════════════════════════════════════════════════════════
# COMMAND: provision
# ═══════════════════════════════════════════════════════════════════


def cmd_provision(args):
    version = args.version
    masters = args.masters
    replicas = args.replicas_per_master
    header(f"Provisioning Redis Cluster v{version} ({masters}M + {masters * replicas}R)")
    preflight()
    log_step("Cleaning up any previous infrastructure...")
    infra_down()
    infra_up()
    log_step(f"Installing Redis {version} on all nodes...")
    run_playbook("provision.yml", extra_vars={
        "redis_version_override": version,
        "masters_count_override": str(masters),
        "replicas_per_master_override": str(replicas),
    })
    log_ok("Provision complete!")


# ═══════════════════════════════════════════════════════════════════
# COMMAND: status
# ═══════════════════════════════════════════════════════════════════


def cmd_status(_args):
    header("Redis Cluster Status")
    preflight()
    run_playbook("status.yml")


# ═══════════════════════════════════════════════════════════════════
# COMMAND: data seed / data verify
# ═══════════════════════════════════════════════════════════════════


def cmd_data_seed(args):
    header(f"Seeding {args.keys} Keys")
    preflight()
    run_playbook("seed.yml", extra_vars={"num_keys": str(args.keys)})


def cmd_data_verify(args):
    header("Verifying Data Integrity")
    preflight()
    run_playbook("verify.yml", extra_vars={"num_keys": str(args.keys)})


# ═══════════════════════════════════════════════════════════════════
# COMMAND: upgrade (rolling, zero-downtime)
# ═══════════════════════════════════════════════════════════════════


def cmd_upgrade(args):
    target = args.target_version
    header(f"Rolling Upgrade to Redis {target}")
    preflight()

    # Step 1 — Pre-flight
    log_step("Step 1/5: Pre-flight health checks...")
    if "cluster_state:ok" not in redis_cli(ALL_IPS[0], "cluster info"):
        abort("Cluster not healthy — aborting")
    log_ok("Cluster state: ok")

    for ip in ALL_IPS:
        if redis_cli(ip, "ping").strip() != "PONG":
            abort(f"Node {ip} not responding — aborting")
        log_ok(f"Node {ip}: reachable")

    log_step("Baseline data verification...")
    run_playbook("verify.yml", extra_vars={"num_keys": "1000"})
    log_ok("Baseline data: intact")

    # Step 2 — Discover topology
    log_step("Step 2/5: Discovering cluster topology...")
    nodes = get_cluster_nodes()
    replicas = [n for n in nodes if n["role"] == "slave"]
    masters = [n for n in nodes if n["role"] == "master"]
    log_info(f"Masters:  {', '.join(n['name'] for n in masters)}")
    log_info(f"Replicas: {', '.join(n['name'] for n in replicas)}")

    # Step 3 — Upgrade replicas
    log_step("Step 3/5: Upgrading replicas...")
    for rep in replicas:
        log_step(f"Upgrading replica {rep['name']} ({rep['ip']})...")
        run_playbook("upgrade.yml", extra_vars={
            "upgrade_node": rep["name"], "target_version": target,
        })
        wait_cluster_ok(f"after upgrading {rep['name']}")
        log_ok(f"Replica {rep['name']} upgraded")

    # Step 4 — Upgrade masters with failover
    log_step("Step 4/5: Upgrading masters with failover...")
    nodes = get_cluster_nodes()  # re-discover after replica upgrades
    masters = [n for n in nodes if n["role"] == "master"]
    rep_for_master = {}
    for n in nodes:
        if n["role"] == "slave":
            rep_for_master[n["master_id"]] = n

    for master in masters:
        mname, mip, mid = master["name"], master["ip"], master["id"]
        rep = rep_for_master.get(mid)
        if not rep:
            abort(f"No replica for master {mname} — ABORTING")

        log_step(f"Failing over {mname} → promoting {rep['name']}...")
        redis_cli(rep["ip"], "CLUSTER FAILOVER")

        for _ in range(30):
            if "role:master" in redis_cli(rep["ip"], "INFO replication"):
                log_ok(f"Failover done: {rep['name']} is master")
                break
            time.sleep(2)
        else:
            abort(f"Failover timed out for {mname}")

        wait_cluster_ok(f"after failover of {mname}")

        log_step(f"Upgrading old master {mname} (now replica)...")
        run_playbook("upgrade.yml", extra_vars={
            "upgrade_node": mname, "target_version": target,
        })
        wait_cluster_ok(f"after upgrading {mname}")
        log_ok(f"Master {mname} upgraded")

    # Step 5 — Post-upgrade verification
    log_step("Step 5/5: Post-upgrade verification...")
    run_playbook("verify.yml", extra_vars={"num_keys": "1000"})
    run_playbook("status.yml")

    header(f"Upgrade Complete — All Nodes at v{target}")
    log_ok("Data integrity: VERIFIED")
    log_ok("Cluster state: OK")
    log_ok("Zero-downtime rolling upgrade successful!")


# ═══════════════════════════════════════════════════════════════════
# COMMAND: verify --full
# ═══════════════════════════════════════════════════════════════════


def cmd_verify(args):
    header("Full Cluster Verification")
    preflight()

    # 1 — Data integrity
    log_step("1. Data integrity check...")
    run_playbook("verify.yml", extra_vars={"num_keys": "1000"})
    log_ok("Data integrity: PASS")

    # 2 — Version consistency
    log_step("2. Version consistency...")
    versions = []
    for ip in ALL_IPS:
        info = redis_cli(ip, "INFO server")
        ver = next((l.split(":")[1].strip() for l in info.splitlines()
                     if l.startswith("redis_version:")), "?")
        versions.append(ver)
        log_info(f"  {ip} ({IP_TO_NAME.get(ip)}): v{ver}")
    unique = set(v for v in versions if v != "?")
    if len(unique) == 1:
        log_ok(f"Version consistency: PASS (all v{unique.pop()})")
    else:
        log_fail(f"Version consistency: FAIL (mixed: {unique})")

    # 3 — Cluster state
    log_step("3. Cluster state...")
    info = redis_cli(ALL_IPS[0], "cluster info")
    log_ok("Cluster state: OK") if "cluster_state:ok" in info else log_fail("NOT OK")

    # 4 — Slot coverage
    log_step("4. Slot coverage...")
    for line in info.splitlines():
        if "cluster_slots_ok" in line:
            slots = line.split(":")[1].strip()
            (log_ok if slots == "16384" else log_fail)(f"Slot coverage: {slots}/16384")

    # 5 — Replication lag (--full)
    if args.full:
        log_step("5. Replication lag...")
        for ip in ALL_IPS:
            repl = redis_cli(ip, "INFO replication")
            if "role:slave" in repl:
                offsets = [l for l in repl.splitlines() if "repl_offset" in l]
                log_info(f"  {ip} (replica): {'; '.join(offsets)}")

    header("Verification Complete")


# ═══════════════════════════════════════════════════════════════════
# COMMAND: infra up/down
# ═══════════════════════════════════════════════════════════════════


def cmd_infra_up(_args):
    preflight()
    infra_up()


def cmd_infra_down(_args):
    preflight()
    infra_down()


# ═══════════════════════════════════════════════════════════════════
# MAIN — ARGPARSE DISPATCHER
# ═══════════════════════════════════════════════════════════════════

BANNER = """
  ╔══════════════════════════════════════════════════════╗
  ║          redis-tool · Cluster Lifecycle CLI          ║
  ╚══════════════════════════════════════════════════════╝
"""


def main():
    parser = argparse.ArgumentParser(
        prog="redis-tool",
        description="Redis Cluster Lifecycle CLI — provision, operate, and upgrade.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=BANNER,
    )
    sub = parser.add_subparsers(dest="command", help="Available commands")

    # provision
    p = sub.add_parser("provision", help="Provision a Redis Cluster")
    p.add_argument("--version", default="7.0.15")
    p.add_argument("--masters", type=int, default=3)
    p.add_argument("--replicas-per-master", type=int, default=1)
    p.set_defaults(func=cmd_provision)

    # status
    p = sub.add_parser("status", help="Show cluster status")
    p.set_defaults(func=cmd_status)

    # data
    p_data = sub.add_parser("data", help="Seed or verify data")
    ds = p_data.add_subparsers(dest="data_cmd")
    p = ds.add_parser("seed", help="Seed test data")
    p.add_argument("--keys", type=int, default=1000)
    p.set_defaults(func=cmd_data_seed)
    p = ds.add_parser("verify", help="Verify data integrity")
    p.add_argument("--keys", type=int, default=1000)
    p.set_defaults(func=cmd_data_verify)

    # upgrade
    p = sub.add_parser("upgrade", help="Rolling upgrade")
    p.add_argument("--target-version", required=True)
    p.add_argument("--strategy", default="rolling", choices=["rolling"])
    p.set_defaults(func=cmd_upgrade)

    # verify
    p = sub.add_parser("verify", help="Full cluster verification")
    p.add_argument("--full", action="store_true")
    p.set_defaults(func=cmd_verify)

    # infra
    p_infra = sub.add_parser("infra", help="Manage containers")
    isub = p_infra.add_subparsers(dest="infra_cmd")
    p = isub.add_parser("up", help="Bring up containers")
    p.set_defaults(func=cmd_infra_up)
    p = isub.add_parser("down", help="Tear down containers")
    p.set_defaults(func=cmd_infra_down)

    args = parser.parse_args()

    if not args.command:
        print(BANNER)
        parser.print_help()
        sys.exit(0)

    if hasattr(args, "func"):
        args.func(args)
    else:
        parser.parse_args([args.command, "--help"])


if __name__ == "__main__":
    main()
