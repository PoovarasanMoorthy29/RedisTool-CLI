# Redis Configuration - Managed by Ansible
# Version: {{ redis_version }}
# Node: {{ inventory_hostname }} ({{ ansible_host }})

# Network
bind {{ redis_bind_address }}
port {{ redis_port }}
protected-mode no
tcp-backlog 511
timeout 0
tcp-keepalive 300

# General
daemonize {{ redis_daemonize }}
pidfile {{ redis_pid_file }}
loglevel notice
logfile {{ redis_log_file }}
databases 16

# Snapshotting
save 900 1
save 300 10
save 60 10000
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes
dbfilename dump.rdb
dir {{ redis_dir }}

# Append Only Mode
appendonly {{ redis_appendonly }}
appendfilename "appendonly.aof"
appendfsync {{ redis_appendfsync }}
no-appendfsync-on-rewrite no
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb

# Memory
maxmemory {{ redis_maxmemory }}
maxmemory-policy {{ redis_maxmemory_policy }}

# Cluster
cluster-enabled {{ redis_cluster_enabled }}
cluster-config-file {{ redis_cluster_config_file }}
cluster-node-timeout {{ redis_cluster_node_timeout }}
cluster-announce-ip {{ redis_node_ip }}
cluster-announce-port {{ redis_port }}
cluster-announce-bus-port {{ redis_cluster_bus_port }}

# Slow Log
slowlog-log-slower-than 10000
slowlog-max-len 128

# Latency Monitor
latency-monitor-threshold 0

# Active Defragmentation
activedefrag no
